# ASTRA — Complete Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local to git.

# ---------------------------------------------------------------------------
# App URL
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://astra.app

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# AI / OpenRouter
# ---------------------------------------------------------------------------
# Server-side ONLY — never prefix with NEXT_PUBLIC_
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------------------
# Clerk Authentication
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/birth-form

# ---------------------------------------------------------------------------
# Neon PostgreSQL (Prisma)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/db?sslmode=require

# ---------------------------------------------------------------------------
# Razorpay (use test keys for development)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_here

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
NODE_ENV=development
