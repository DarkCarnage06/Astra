# ASTRA — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# URL of the FastAPI backend server
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# AI / OpenRouter
# ---------------------------------------------------------------------------
# Your OpenRouter API key — get one at https://openrouter.ai
# This key is SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------------------
# Optional: Force a specific model
# (defaults to the primary model in config/models.ts)
# ---------------------------------------------------------------------------
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
# development | production
NODE_ENV=development
